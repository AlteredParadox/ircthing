# Copy to .env and edit. Compose reads this automatically.

# The public hostname Caddy serves and requests a TLS certificate for.
# Must resolve to this host, with ports 80 and 443 reachable from the
# internet for the ACME challenge. Use "localhost" for a local test
# (Caddy then issues an internal self-signed cert).
IRCTHING_DOMAIN=irc.example.org

# Contact address Let's Encrypt uses for expiry notices. Optional but
# recommended for a real domain; leave blank for localhost.
ACME_EMAIL=you@example.org

# Version string stamped into the image's About panel. `make docker` sets a
# real `git describe` value; override here if you build via plain compose.
IRCTHING_VERSION=docker
