# Keep the build context small and reproducible: exclude local build output,
# secrets, and anything the image rebuilds itself.

.git
.gitignore

# Rebuilt inside the image (frontend stage / go build)
web/node_modules
web/dist
bin/
/ircd-web

# Secrets and local runtime state — never bake these into an image. Recursive
# (**/) so nested copies (e.g. deploy/docker/config.json, deploy/docker/.env)
# are excluded too, not just the ones at the context root.
**/config.json
**/.env
**/*.db
**/*.db-wal
**/*.db-shm
**/*.key
**/*.pem
*.log
*.pid

# Not needed to build the binary
design/
docs/
integration/
.cache/
sonar-issues.md

# Editor / OS cruft
*.swp
*.swo
*~
.DS_Store
