# Built binary
/bin/
# Stray root-level build output (go build with no -o lands here)
/ircd-web

# Local config (contains credentials); config.example.json is the template
/config.json

# Runtime logs
*.log

# Tool cache (ergo build for make integration)
/.cache/

# SQLite databases
*.db
*.db-wal
*.db-shm

# Frontend build output (keep .gitkeep so go:embed works in a fresh checkout)
web/dist/*
!web/dist/.gitkeep

# Node
web/node_modules/

# Design-tool export artifact
.thumbnail

# Local worklist exported from SonarQube findings; never committed
/sonar-issues.md

# Python bytecode (irctest controller)
__pycache__/
*.py[cod]
