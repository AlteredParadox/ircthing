# Built binary
/bin/
# Stray root-level build output (go build with no -o lands here)
/ircd-web

# Local config (contains credentials); config.example.json is the template
/config.json
# Docker compose local config + env (credentials / domain); the *.example
# files are the templates. Never commit the real ones. The glob also catches
# config.json.bak and similar so a stray credential backup can't slip in.
/deploy/docker/config.json*
/deploy/docker/.env

# Runtime logs
*.log

# Tool cache (ergo build for make integration)
/.cache/

# SQLite databases
*.db
*.db-wal
*.db-shm

# Frontend build output (keep .gitkeep so go:embed works in a fresh checkout)
web/dist/*
!web/dist/.gitkeep

# Node
web/node_modules/

# Design-tool export artifact
.thumbnail

# Local worklist exported from SonarQube findings; never committed
/sonar-issues.md

# Python bytecode (irctest controller)
__pycache__/
*.py[cod]

# Editor swap/backup files
*.swp
*.swo
*~

# Design-tool runtime (Claude Design output, unclear redistribution license for the
# bundled dc-runtime). Kept locally so design/*.dc.html renders; not published.
design/support.js
*.pid
